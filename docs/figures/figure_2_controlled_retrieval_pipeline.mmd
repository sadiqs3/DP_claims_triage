flowchart LR

    subgraph PREP["Offline Knowledge-Base Preparation"]
        A["7 Approved Synthetic<br/>Knowledge Documents"]
        B["Source Allow-List and<br/>Metadata Validation"]
        C["Section-Aware<br/>Corpus Builder"]
        D["21 Traceable<br/>Knowledge Chunks"]
        E["OpenAI Embeddings<br/>text-embedding-3-small<br/>1536 Dimensions"]
        F["Persisted FAISS Index<br/>IndexFlatIP"]
        G["Index Manifest<br/>Corpus Fingerprint<br/>Chunk-Order Fingerprint"]
    end

    subgraph QUERY["Runtime Controlled Query Construction"]
        H["Authoritative Triage Facts<br/>Outcome, Rule, Coverage,<br/>Evidence and Review State"]
        I["Allow-Listed Fact Projection"]
        J["Controlled Retrieval Query"]
        K["Customer Narrative and<br/>Identifiers Excluded"]
    end

    subgraph RETRIEVAL["Runtime Retrieval"]
        L["Query Embedding"]
        M["FAISS Exact<br/>Similarity Search"]
        N["Bounded Candidate Set"]
        O{"Optional Cross-Encoder<br/>Reranking Enabled?"}
        P["Cross-Encoder Reranker<br/>ms-marco-MiniLM-L-6-v2"]
        Q["Top-K Approved<br/>Knowledge Chunks"]
        R["Analyst-Guidance Formatter"]
    end

    subgraph CONTROL["Validation and Authority Controls"]
        S["Corpus and Index<br/>Consistency Validation"]
        T["Stale or Mismatched<br/>Index Blocked"]
        U["Non-Authoritative<br/>Operational Guidance"]
    end

    A --> B
    B --> C
    C --> D
    D --> E
    E --> F
    D --> G
    F --> G

    H --> I
    K -. "Explicitly excluded" .-> I
    I --> J
    J --> L

    G --> S
    S -->|Valid| M
    S -->|Mismatch| T

    L --> M
    M --> N
    N --> O
    O -->|Yes| P
    P --> Q
    O -->|No| Q
    Q --> R
    R --> U

    classDef source fill:#F7F7F7,stroke:#555555,stroke-width:1px;
    classDef preparation fill:#DCEAF7,stroke:#24527A,stroke-width:1.5px;
    classDef query fill:#E8E3F3,stroke:#5B467A,stroke-width:1.5px;
    classDef retrieval fill:#E7F1E8,stroke:#3D6841,stroke-width:1.5px;
    classDef control fill:#F8E8D8,stroke:#8A572A,stroke-width:1.5px;
    classDef blocked fill:#F4DEDE,stroke:#7A3434,stroke-width:1.5px;

    class A source;
    class B,C,D,E,F,G preparation;
    class H,I,J,K query;
    class L,M,N,O,P,Q,R retrieval;
    class S,U control;
    class T blocked;