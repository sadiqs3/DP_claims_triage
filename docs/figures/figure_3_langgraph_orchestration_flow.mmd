flowchart TB

    START(["START"])

    A["Claim Input<br/>Claim ID and Runtime Records"]

    B["deterministic_triage<br/><br/>Execute policy, plan, device,<br/>coverage, history, evidence,<br/>risk and rule-precedence checks"]

    C["Authoritative Triage State<br/><br/>Outcome<br/>Triggering Rule<br/>Decision Reason<br/>Rule Trace"]

    D["controlled_follow_up_selection<br/><br/>Select approved catalogue question<br/>when additional information is required"]

    E{"Controlled RAG<br/>Enabled?"}

    F["controlled_rag_retrieval<br/><br/>Build query from allow-listed<br/>AuthoritativeTriageFacts"]

    G["FAISS Semantic Retrieval<br/><br/>Approved knowledge base<br/>Top-K chunks"]

    H{"Optional Cross-Encoder<br/>Reranking Enabled?"}

    I["Cross-Encoder Reranking<br/><br/>Reorder bounded approved<br/>candidate chunks"]

    J["Retrieved Analyst Guidance<br/><br/>Non-authoritative operational context"]

    K["explanation_proposal<br/><br/>Generate analyst-facing explanation<br/>from authoritative facts and guidance"]

    L["agent_content_safety_guardrail<br/><br/>Detect prohibited content,<br/>unsafe authority claims and overrides"]

    M{"Generated Content<br/>Safe?"}

    N["Controlled Safety Fallback<br/><br/>Replace unsafe explanation while<br/>preserving deterministic result"]

    O["response_guardrail<br/><br/>Compare final response with<br/>protected deterministic state"]

    P{"Outcome, Rule and<br/>Follow-Up Aligned?"}

    Q["Restore Protected Values<br/><br/>Block attempted override and retain<br/>authoritative workflow fields"]

    R["Final Protected Response<br/><br/>Disposition<br/>Triggering Rule<br/>Approved Follow-Up<br/>Analyst Guidance<br/>Human-Control Notice"]

    S["Authorised Human Review"]

    END(["END"])

    START --> A
    A --> B
    B --> C
    C --> D
    D --> E

    E -->|Yes| F
    F --> G
    G --> H
    H -->|Yes| I
    I --> J
    H -->|No| J

    E -->|No| K
    J --> K

    K --> L
    L --> M

    M -->|Yes| O
    M -->|No| N
    N --> O

    O --> P
    P -->|Yes| R
    P -->|No| Q
    Q --> R

    C -. "Protected outcome,<br/>rule and trace" .-> O
    D -. "Protected approved<br/>follow-up selection" .-> O

    R --> S
    S --> END

    classDef input fill:#F7F7F7,stroke:#555555,stroke-width:1px;
    classDef authoritative fill:#DCEAF7,stroke:#24527A,stroke-width:1.5px;
    classDef orchestration fill:#E8E3F3,stroke:#5B467A,stroke-width:1.5px;
    classDef retrieval fill:#E7F1E8,stroke:#3D6841,stroke-width:1.5px;
    classDef guardrail fill:#F8E8D8,stroke:#8A572A,stroke-width:1.5px;
    classDef fallback fill:#F4DEDE,stroke:#7A3434,stroke-width:1.5px;
    classDef human fill:#FFF4CC,stroke:#806A1A,stroke-width:1.5px;
    classDef terminal fill:#FFFFFF,stroke:#333333,stroke-width:1.5px;

    class A input;
    class B,C authoritative;
    class D,E,F,K orchestration;
    class G,H,I,J retrieval;
    class L,M,O,P,R guardrail;
    class N,Q fallback;
    class S human;
    class START,END terminal;